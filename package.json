  "author": "christopherlhammer11-ai",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/christopherlhammer11-ai/real-time-verifier"
  },
  "files": ["dist", "README.md"],
  "engines": { "node": ">=18" },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  }
}
